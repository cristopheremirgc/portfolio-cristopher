---
import "../styles/global.css";
import "../styles/macos.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Portfolio",
  description = "Portfolio web interactivo inspirado en una interfaz de escritorio.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#111827" />
    <title>{title}</title>
  </head>

  <body>
    <slot />
  </body>
</html>