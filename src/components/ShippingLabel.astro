---
// ShippingLabel.astro
// Estilo pegatina de envío paquetería - inspirado en LAYOVER

interface Props {
  date?: string;
  orderNumber?: string;
  albumName?: string;
  version?: string;
  versionCode?: string;
  quantity?: string;
  toName?: string;
  toPhone?: string;
  fromName?: string;
  fromAddress?: string;
  fromPhone?: string;
  memo?: string;
  memoLine2?: string;
  tracklist?: string[];
  extraItem?: string;
  weight?: string;
  labelCode?: string;
  copies?: string;
  barcodeId?: string;
}

const {
  date = "2023.09.08",
  orderNumber = "2023-0908-0001",
  albumName = "V-1st-Mini-Album-LAYOVER",
  version = "V",
  versionCode = "v01-1",
  quantity = "1/1",
  toName = "TO. ARMY",
  toPhone = "M. ***-****-****",
  fromName = "FROM. T.H.KIM",
  fromAddress = "1F, LAYOVER B/D [SEOUL]",
  fromPhone = "M. ***-****-****",
  memo = "안전하게 배송 부탁드립니다 :)",
  memoLine2 = "부재중일 경우 문자주세요.",
  tracklist = [
    "RAINY DAYS",
    "BLUE",
    "LOVE ME AGAIN...",
    "SLOW DANCING*",
    "FOR US",
    "++SLOW DANCING (Piano Ver.)",
    "MORE ITEM (for you)",
  ],
  extraItem = "Layover",
  weight = "2.74",
  labelCode = "로스",
  copies = "X6",
  barcodeId = "1230-9999",
} = Astro.props;
---

<div class="label-wrapper">
  <div class="label">

    <!-- TOP BAR -->
    <div class="top-bar">
      <div class="top-left">
        <div class="photo-placeholder">
          <span>PHOTO</span>
        </div>
        <div class="top-meta">
          <p class="top-date">{date}</p>
          <p>☎ {barcodeId}</p>
          <p>성건호 {orderNumber}</p>
          <p class="album-name">{albumName}</p>
        </div>
      </div>
      <div class="top-right">
        <div class="qty-version">
          <span class="quantity">{quantity}</span>
          <span class="version-letter">{version}</span>
        </div>
        <div class="version-code">{versionCode}</div>
      </div>
    </div>

    <!-- ADDRESS BLOCK -->
    <div class="address-block">
      <div class="address-to">
        <p class="addr-title">{toName}</p>
        <p class="addr-phone">{toPhone}</p>
        <div class="memo-box">
          <span class="memo-tag">메모</span>
          <div class="memo-text">
            <p>{memo}</p>
            <p>{memoLine2}</p>
          </div>
        </div>
      </div>
      <div class="address-from">
        <div class="from-header">
          <p class="addr-title">{fromName}</p>
          <div class="label-code-box">{labelCode}</div>
        </div>
        <p class="from-address">{fromAddress}</p>
        <p class="addr-phone">{fromPhone}</p>
        <div class="weight-row">
          <div class="qty-row">
            <div class="qty-cell"><span class="cell-label">수량</span><span class="cell-val">1</span></div>
            <div class="qty-cell"><span class="cell-label">문임</span><span class="cell-val">0</span></div>
            <div class="qty-cell highlight"><span class="cell-label">정산</span><span class="cell-val">선불</span></div>
          </div>
          <div class="weight-info">
            <p class="copies">{copies}</p>
            <p class="weight">{weight} kg</p>
            <p class="weight">{weight} kg</p>
          </div>
        </div>
      </div>
    </div>

    <!-- DIVIDER WITH BARCODES -->
    <div class="content-section">
      <!-- Barcode izquierdo -->
      <div class="barcode-left">
        <div class="barcode vertical">
          {Array.from({ length: 28 }).map((_, i) => (
            <div
              class="bar"
              style={`height: ${Math.random() > 0.35 ? "100%" : "65%"}; width: ${Math.random() > 0.5 ? "3px" : "2px"};`}
            />
          ))}
        </div>
        <p class="barcode-label">{orderNumber}</p>
      </div>

      <!-- Tracklist -->
      <div class="tracklist">
        {tracklist.map((track) => (
          <p class="track">{track}</p>
        ))}
        <p class="extra-item handwritten">{extraItem}</p>
      </div>

      <!-- Barcode derecho -->
      <div class="barcode-right">
        <div class="barcode vertical">
          {Array.from({ length: 28 }).map((_, i) => (
            <div
              class="bar"
              style={`height: ${Math.random() > 0.35 ? "100%" : "65%"}; width: ${Math.random() > 0.5 ? "3px" : "2px"};`}
            />
          ))}
        </div>
        <p class="barcode-label rotated">{albumName}</p>
      </div>
    </div>

    <!-- YELLOW HIGHLIGHT STRIP -->
    <div class="highlight-strip">
      <span class="strip-left handwritten big">{extraItem}</span>
      <div class="strip-right">
        <span class="strip-tag">일반</span>
        <span class="strip-tag">정산</span>
        <span class="strip-tag accent">선불</span>
      </div>
    </div>

    <!-- FOOTER -->
    <div class="label-footer">
      <div class="footer-left">
        <div class="mini-barcode">
          {Array.from({ length: 20 }).map((_, i) => (
            <div class="bar" style={`height: ${Math.random() > 0.4 ? "100%" : "60%"}; width: 2px;`} />
          ))}
        </div>
        <p class="footer-date">{date}</p>
      </div>
      <div class="footer-legal">
        <p>DISTRIBUTED BY HYBE/YG PLUS, INC. KOREA. WARNING: ALL RIGHTS RESERVED.</p>
        <p>UNAUTHORIZED DUPLICATION & RENT IS PROHIBITED. PRINTED IN KOREA</p>
      </div>
    </div>

  </div>
</div>

<style>
  @import url("https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;700&family=Noto+Sans+KR:wght@400;700&display=swap");

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  .label-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 2rem;
    background: #e8e4dc;
    min-height: 100vh;
    font-family: "IBM Plex Mono", "Courier New", monospace;
  }

  .label {
    background: #f7f4ef;
    border: 1.5px solid #2a2a2a;
    width: 100%;
    max-width: 620px;
    overflow: hidden;
    box-shadow: 6px 6px 0 #2a2a2a;
  }

  /* ── TOP BAR ── */
  .top-bar {
    display: flex;
    justify-content: space-between;
    align-items: stretch;
    border-bottom: 1.5px solid #2a2a2a;
    background: #f7f4ef;
  }

  .top-left {
    display: flex;
    gap: 0.6rem;
    padding: 0.5rem 0.7rem;
    flex: 1;
  }

  .photo-placeholder {
    width: 54px;
    height: 54px;
    background: #c8c4be;
    border: 1px solid #2a2a2a;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.45rem;
    color: #555;
    flex-shrink: 0;
  }

  .top-meta {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.15rem;
  }

  .top-meta p {
    font-size: 0.55rem;
    color: #2a2a2a;
    line-height: 1.3;
  }

  .top-date {
    font-weight: 700;
  }

  .album-name {
    font-size: 0.5rem !important;
    color: #555 !important;
  }

  .top-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: center;
    padding: 0.4rem 0.7rem;
    border-left: 1.5px solid #2a2a2a;
    background: #ede9e1;
    min-width: 130px;
    gap: 0.1rem;
  }

  .qty-version {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }

  .quantity {
    font-size: 0.9rem;
    font-weight: 700;
    color: #2a2a2a;
  }

  .version-letter {
    font-size: 1.2rem;
    font-weight: 700;
    color: #2a2a2a;
  }

  .version-code {
    font-size: 2rem;
    font-weight: 900;
    color: #2a2a2a;
    letter-spacing: -0.04em;
    line-height: 1;
  }

  /* ── ADDRESS BLOCK ── */
  .address-block {
    display: flex;
    border-bottom: 1.5px solid #2a2a2a;
  }

  .address-to {
    flex: 1;
    padding: 0.6rem 0.8rem;
    border-right: 1.5px solid #2a2a2a;
  }

  .address-from {
    flex: 1.1;
    padding: 0.6rem 0.8rem;
  }

  .addr-title {
    font-size: 0.7rem;
    font-weight: 700;
    color: #2a2a2a;
    margin-bottom: 0.2rem;
  }

  .addr-phone {
    font-size: 0.55rem;
    color: #2a2a2a;
    margin-bottom: 0.3rem;
    font-family: "Noto Sans KR", sans-serif;
  }

  .memo-box {
    display: flex;
    gap: 0.4rem;
    border: 1px solid #2a2a2a;
    padding: 0.3rem 0.4rem;
    margin-top: 0.3rem;
    background: #fff;
  }

  .memo-tag {
    font-size: 0.5rem;
    font-weight: 700;
    border: 1px solid #2a2a2a;
    padding: 0.1rem 0.25rem;
    height: fit-content;
    white-space: nowrap;
    font-family: "Noto Sans KR", sans-serif;
    background: #ede9e1;
  }

  .memo-text p {
    font-size: 0.52rem;
    color: #2a2a2a;
    font-family: "Noto Sans KR", sans-serif;
    line-height: 1.5;
  }

  .from-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .label-code-box {
    font-size: 0.5rem;
    border: 1px solid #2a2a2a;
    padding: 0.15rem 0.4rem;
    font-weight: 700;
    background: #fff;
  }

  .from-address {
    font-size: 0.55rem;
    color: #2a2a2a;
    margin-bottom: 0.2rem;
  }

  .weight-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-top: 0.4rem;
  }

  .qty-row {
    display: flex;
    gap: 0.3rem;
  }

  .qty-cell {
    display: flex;
    gap: 0.2rem;
    align-items: center;
    border: 1px solid #2a2a2a;
    padding: 0.1rem 0.3rem;
    font-size: 0.5rem;
    background: #fff;
  }

  .qty-cell.highlight {
    background: #2a2a2a;
    color: #f7f4ef;
  }

  .cell-label {
    font-family: "Noto Sans KR", sans-serif;
    font-size: 0.45rem;
  }

  .cell-val {
    font-weight: 700;
    font-size: 0.52rem;
  }

  .weight-info {
    text-align: right;
  }

  .copies {
    font-size: 0.55rem;
    font-weight: 700;
    color: #2a2a2a;
  }

  .weight {
    font-size: 0.6rem;
    font-weight: 700;
    color: #2a2a2a;
    line-height: 1.3;
  }

  /* ── CONTENT SECTION ── */
  .content-section {
    display: flex;
    gap: 0;
    min-height: 160px;
    border-bottom: 1.5px solid #2a2a2a;
  }

  .barcode-left,
  .barcode-right {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0.5rem 0.4rem;
    gap: 0.3rem;
  }

  .barcode-right {
    border-left: 1.5px solid #2a2a2a;
  }

  .barcode-left {
    border-right: 1.5px solid #2a2a2a;
  }

  .barcode.vertical {
    display: flex;
    align-items: flex-end;
    gap: 1.5px;
    height: 80px;
  }

  .bar {
    background: #2a2a2a;
    display: inline-block;
    align-self: flex-end;
  }

  .barcode-label {
    font-size: 0.38rem;
    color: #2a2a2a;
    text-align: center;
    font-weight: 700;
    max-width: 40px;
    word-break: break-all;
    line-height: 1.3;
  }

  .rotated {
    writing-mode: vertical-rl;
    text-orientation: mixed;
    max-width: none;
    max-height: 80px;
  }

  /* ── TRACKLIST ── */
  .tracklist {
    flex: 1;
    padding: 0.7rem 1rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.25rem;
  }

  .track {
    font-size: 0.62rem;
    color: #2a2a2a;
    letter-spacing: 0.05em;
    font-weight: 400;
    line-height: 1.4;
  }

  .extra-item {
    margin-top: 0.3rem;
  }

  .handwritten {
    font-family: "Segoe Script", "Caveat", "Dancing Script", cursive;
    font-size: 1.1rem !important;
    color: #2a2a2a;
    font-weight: 400;
    line-height: 1.2;
  }

  /* ── YELLOW STRIP ── */
  .highlight-strip {
    background: #d4c97a;
    border-bottom: 1.5px solid #2a2a2a;
    padding: 0.4rem 0.8rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .strip-left.big {
    font-size: 2rem !important;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .strip-right {
    display: flex;
    gap: 0.3rem;
    align-items: center;
  }

  .strip-tag {
    font-size: 0.65rem;
    font-weight: 700;
    border: 1.5px solid #2a2a2a;
    padding: 0.2rem 0.5rem;
    background: #f7f4ef;
    font-family: "Noto Sans KR", sans-serif;
  }

  .strip-tag.accent {
    background: #2a2a2a;
    color: #f7f4ef;
  }

  /* ── FOOTER ── */
  .label-footer {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.4rem 0.7rem;
    background: #eeeae2;
  }

  .footer-left {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    flex-shrink: 0;
  }

  .mini-barcode {
    display: flex;
    align-items: flex-end;
    gap: 1px;
    height: 25px;
  }

  .footer-date {
    font-size: 0.45rem;
    font-weight: 700;
    color: #2a2a2a;
  }

  .footer-legal {
    flex: 1;
  }

  .footer-legal p {
    font-size: 0.38rem;
    color: #555;
    line-height: 1.5;
    letter-spacing: 0.02em;
  }
</style>