---
interface Props {
  name: string;
  role: string;
}

const { name, role } = Astro.props;
const initialDate = new Date();
---

<header class="menu-bar" aria-label="Barra superior">
  <div class="menu-bar__brand">
    <span class="menu-bar__brand-mark" aria-hidden="true"></span>

    <div class="menu-bar__identity">
      <strong>{name}</strong>
      <span>{role}</span>
    </div>
  </div>

  <nav class="menu-bar__nav" aria-label="Menú principal">
    <button type="button" data-window-open="about">About</button>
    <button type="button" data-window-open="projects">Proyectos</button>
    <button type="button" data-window-open="career">Carrera</button>
    <button type="button" data-window-open="contact">Contacto</button>
  </nav>

  <div class="menu-bar__status">
    <span class="menu-bar__status-dot" aria-hidden="true"></span>
    <time data-clock datetime={initialDate.toISOString()}>
      {initialDate.toLocaleTimeString("es-MX", {
        hour: "2-digit",
        minute: "2-digit",
      })}
    </time>
  </div>
</header>